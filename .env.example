# The agent's EVM private key. It is the agent's identity (keyless auth) and the
# x402 payer. Fund this address with USDC on Base (chain 8453) before `npm run
# buy` — no ETH needed (x402's EIP-3009 transfer is gasless for the signer).
AGENT_PRIVATE_KEY=0x...

# Optional overrides.
# REALMINT_BASE_URL=https://api.realmint.io
# AMOUNT_USDC=5
# ASSET_ID=tslax
# SELL_AMOUNT=          # asset units to sell; defaults to the full wallet balance
# SOLANA_RPC=https://api.mainnet-beta.solana.com
